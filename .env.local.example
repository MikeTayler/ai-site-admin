# Clerk — create an application at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Custom auth URLs (match middleware public routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Postgres (Vercel Postgres, Supabase, Neon, or local) — used by Prisma
DATABASE_URL=
# If you use Vercel’s Neon integration with a custom prefix, vars look like
# PREFIX_POSTGRES_PRISMA_URL instead of DATABASE_URL. The app maps those automatically
# at runtime; for `prisma migrate deploy` from the CLI you still need DATABASE_URL
# in the shell or duplicate it in Vercel as DATABASE_URL = same value as *_POSTGRES_PRISMA_URL.

# OpenRouter (OpenAI-compatible API) — AI engine
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# Optional: path to `ai-site-components` repo root. If unset, resolution order is:
# 1) data/component-schemas (bundled *.schema.json in this repo, works on Vercel)
# 2) node_modules/@ai-site/components
# 3) ../ai-site-components
# COMPONENT_LIBRARY_ROOT=

# GitHub API (repo scope) — for client site git integration
GITHUB_TOKEN=

# Vercel API — deploy monitoring & project env (https://vercel.com/account/tokens)
VERCEL_TOKEN=
# Optional: team id when the project belongs to a team (Vercel dashboard → Team Settings)
# VERCEL_TEAM_ID=
